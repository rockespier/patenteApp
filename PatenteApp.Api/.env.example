# Variables de entorno requeridas para el backend
# Copiar este archivo como .env y completar los valores reales (NO subir .env a git)

# MongoDB Atlas - connection string completo
MongoDbSettings__ConnectionString=mongodb+srv://USUARIO:CONTRASEÑA@cluster0.XXXXX.mongodb.net/?appName=Cluster0&retryWrites=true&w=majority

# Entorno de ejecución
ASPNETCORE_ENVIRONMENT=Production

# (Opcional) Si quieres sobreescribir el Project ID de Firebase vía env var:
# Firebase__ProjectId=patenteapp-415a9

# (Opcional) URLs del frontend separadas por punto y coma:
# Cors__AllowedOrigins__0=https://tu-frontend.com
